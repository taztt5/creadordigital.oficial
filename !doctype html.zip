        </div>
        <div class="section-card p-4">
         <p class="text-sm">✅ «Checklist rápido para [tarea de tu nicho]»</p>
        </div>
       </div>
      </div><!-- Sin rostro -->
      <div id="tab-sinrostro" class="ideas-panel hidden">
       <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <div class="section-card p-4">
         <p class="text-sm">🖥️ Screencast con voz en off: tutoriales de software</p>
        </div>
        <div class="section-card p-4">
